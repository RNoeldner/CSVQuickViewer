[*.cs]

# IDE0090: Use 'new(...)'
dotnet_diagnostic.IDE0090.severity = none

# MA0009: Add regex evaluation timeout
dotnet_diagnostic.MA0009.severity = error

MA0051.maximum_lines_per_method = 160
MA0051.maximum_statements_per_method = 60
MA0051.skip_local_functions = true # skip local functions when counting statements

# MA0016: Prefer using collection abstraction instead of implementation
dotnet_diagnostic.MA0016.severity = none
